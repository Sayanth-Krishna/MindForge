datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// User profile mapping metadata matching Supabase auth.users
model Profile {
  id        String        @id // Corresponds to Supabase auth.users.id
  email     String        @unique
  fullName  String?
  avatarUrl String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  subjects  Subject[]
  documents Document[]
  flashcards Flashcard[]
  quizzes   Quiz[]
  chatSessions ChatSession[]
}

// Subjects grouping resources
model Subject {
  id           String        @id @default(uuid())
  name         String
  description  String?
  color        String?       // Hex or CSS color string for UI tagging
  userId       String
  user         Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents    Document[]
  flashcards   Flashcard[]
  quizzes      Quiz[]
  chatSessions ChatSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
}

// Uploaded PDF Notes
model Document {
  id           String          @id @default(uuid())
  name         String
  storagePath  String          // Unique path in Supabase bucket
  fileUrl      String          // Public or signed URL for client rendering
  fileSize     Int             // Bytes size
  summary      String?         @db.Text // Cached summary generated by Gemini
  subjectId    String
  subject      Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  userId       String
  user         Profile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks       DocumentChunk[]
  flashcards   Flashcard[]
  quizzes      Quiz[]
  chatSessions ChatSession[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([subjectId])
  @@index([userId])
}

// Vectorized chunks of the documents
model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  pageNumber Int?
  
  // Custom Unsupported pgvector field. Gemini embedding model uses 768 dimensions.
  embedding  Unsupported("vector(768)")?
  
  createdAt  DateTime @default(now())

  @@index([documentId])
}

// Generated Flashcards
model Flashcard {
  id         String    @id @default(uuid())
  front      String    @db.Text
  back       String    @db.Text
  subjectId  String
  subject    Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([subjectId])
  @@index([documentId])
  @@index([userId])
}

// Generated Quizzes
model Quiz {
  id         String         @id @default(uuid())
  title      String
  subjectId  String
  subject    Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  documentId String?
  document   Document?      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       Profile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions  QuizQuestion[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([subjectId])
  @@index([documentId])
  @@index([userId])
}

model QuizQuestion {
  id                  String   @id @default(uuid())
  quizId              String
  quiz                Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question            String   @db.Text
  options             Json     // String array containing multi-choice options
  correctOptionIndex  Int
  explanation         String?  @db.Text // Detailed explanation for why the option is correct
  createdAt           DateTime @default(now())

  @@index([quizId])
}

// RAG Conversation history
model ChatSession {
  id         String        @id @default(uuid())
  title      String
  subjectId  String
  subject    Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  documentId String?       // Optionally scope chat to a single document
  document   Document?     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([subjectId])
  @@index([documentId])
  @@index([userId])
}

model ChatMessage {
  id         String      @id @default(uuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String      // "user" or "assistant"
  content    String      @db.Text
  
  // JSON array tracking which chunk source items were retrieved for context
  sources    Json?       
  
  createdAt  DateTime    @default(now())

  @@index([sessionId])
}
