# ==============================================================================
# MindForge - Backend Environment Configuration Template
# Copy this file to a new file named '.env' and populate with your credentials.
# ==============================================================================

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Database Connection (Neon PostgreSQL with pgvector)
DATABASE_URL="your-postgresql-neon-connection-string"

# Supabase Credentials
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-public-key"


# Google Gemini API Credentials
GEMINI_API_KEY="your-gemini-api-key"
